# Tina CMS — Required for local dev & production
# Get these from https://tina.io/ after connecting your repo

# 1. Create a new app at https://app.tina.io/
# 2. Copy Client ID from the app settings
TINA_CLIENT_ID=your_tina_client_id_here

# 3. Generate a token: Settings → Access Tokens → New Token
TINA_TOKEN=your_tina_token_here

# Optional: Override the repo (defaults to package.json name)
# REPO=yourusername/your-portfolio-repo
