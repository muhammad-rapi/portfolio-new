---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import Skills from '../components/Skills.astro';
import Timeline from '../components/Timeline.astro';
import Contact from '../components/Contact.astro';

const locale = 'en';
---

<Base
  locale={locale}
  title="Your Name — Full-Stack Developer & UI Engineer"
  description="Full-Stack Developer & UI Engineer. Building fast, beautiful, and purposeful digital experiences."
>
  <Hero locale={locale} name="Your Name" />
  <About locale={locale} name="Your Name" />
  <ProjectsGrid locale={locale} limit={4} />
  <Skills locale={locale} />
  <Timeline locale={locale} />
  <Contact locale={locale} />
</Base>
