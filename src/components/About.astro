---
import { getCollection } from 'astro:content';

interface Props {
  locale?: 'en' | 'id';
  name?: string;
}

const { locale = 'en', name = 'Your Name' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);

const aboutEntries = await getCollection('about');
const about = aboutEntries.find(e =>
  locale === 'en' ? e.id.endsWith('en') : e.id.endsWith('id')
) || aboutEntries[0];

const stats = about?.data.stats || [
  { label: t.about.stats.years, value: '5+' },
  { label: t.about.stats.projects, value: '40+' },
  { label: t.about.stats.clients, value: '20+' },
];

const headline = about?.data.headline || t.about.headline;
---

<section id="about" class="py-24 md:py-36">
  <div class="container-wide">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">

      <!-- Left: Label -->
      <div class="lg:col-span-1">
        <p
          class="reveal-left font-mono text-xs tracking-widest"
          style="color: var(--color-ink-muted); writing-mode: vertical-rl; transform: rotate(180deg);"
        >
          {t.about.label.toUpperCase()}
        </p>
      </div>

      <!-- Center: Text -->
      <div class="lg:col-span-6">
        <!-- Line -->
        <div class="reveal-left mb-8" style="width: 32px; height: 2px; background: var(--color-ink);"></div>

        <h2
          class="reveal font-display font-bold mb-8 leading-tight"
          style="font-size: clamp(1.75rem, 4vw, 2.5rem); letter-spacing: -0.03em; color: var(--color-ink);"
        >
          {headline}
        </h2>
        <p class="reveal text-base leading-relaxed mb-5" style="color: var(--color-ink-muted);">
          {t.about.bio1}
        </p>
        <p class="reveal text-base leading-relaxed" style="color: var(--color-ink-muted);">
          {t.about.bio2}
        </p>

        <!-- Social proof icons -->
        <div class="reveal flex items-center gap-6 mt-10">
          <a href="https://github.com/yourusername" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-xs transition-opacity duration-200 hover:opacity-50"
            style="color: var(--color-ink-muted);">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/yourusername" target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-1.5 text-xs transition-opacity duration-200 hover:opacity-50"
            style="color: var(--color-ink-muted);">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <!-- Right: Stats -->
      <div class="lg:col-span-4 lg:col-start-9 flex flex-col justify-center gap-10">
        {stats.map((stat, i) => (
          <div
            class="reveal group"
            style={`transition-delay: ${i * 100}ms;`}
          >
            <div class="flex items-baseline gap-3 mb-1">
              <p
                class="font-display font-bold"
                style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em; color: var(--color-ink); line-height: 1;"
              >
                {stat.value}
              </p>
              <div class="w-4 h-px mb-2 transition-all duration-300 group-hover:w-8" style="background: var(--color-ink-faint);"></div>
            </div>
            <p class="text-sm" style="color: var(--color-ink-muted);">
              {stat.label}
            </p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
