---
import { getCollection } from 'astro:content';

interface Props {
  locale?: 'en' | 'id';
  name?: string;
}

const { locale = 'en', name = 'Your Name' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);

const aboutEntries = await getCollection('about');
const about = aboutEntries.find(e =>
  locale === 'en' ? e.id.endsWith('en') : e.id.endsWith('id')
) || aboutEntries[0];

let stats = [
  { label: t.about.stats.years, value: '5+' },
  { label: t.about.stats.projects, value: '40+' },
  { label: t.about.stats.clients, value: '20+' },
];
let headline = t.about.headline;
let bioParagraphs = [t.about.bio1, t.about.bio2, t.about.bio3];

if (about?.data.stats) {
  stats = about.data.stats;
}
if (about?.data.headline) {
  headline = about.data.headline;
}
if (about?.body) {
  // body is markdown content, we just use our i18n text for simplicity
}
---

<section id="about" class="section" style="background-color: var(--color-surface);">
  <div class="container-wide">
    <!-- Label -->
    <p class="reveal font-mono text-xs mb-12 tracking-widest uppercase" style="color: var(--color-ink-muted);">
      {t.about.label}
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Text Column -->
      <div class="lg:col-span-7">
        <h2
          class="reveal font-display font-bold mb-8"
          style="font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.03em; color: var(--color-ink);"
        >
          {headline}
        </h2>
        {bioParagraphs.map((p: string) => (
          <p class="reveal text-base mb-4 leading-relaxed" style="color: var(--color-ink-muted);">
            {p}
          </p>
        ))}
      </div>

      <!-- Stats Column -->
      <div class="lg:col-span-5 flex flex-col justify-center">
        <div class="grid grid-cols-1 gap-6">
          {stats.map((stat, i) => (
            <div
              class="reveal border-l-2 pl-6"
              style="border-color: var(--color-ink-faint); transition-delay: {i * 100}ms;"
            >
              <p
                class="font-display font-extrabold"
                style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.04em; color: var(--color-ink); line-height: 1;"
              >
                {stat.value}
              </p>
              <p class="text-sm mt-1 font-mono" style="color: var(--color-ink-muted);">
                {stat.label}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
