---
interface Props {
  locale?: 'en' | 'id';
}
const { locale = 'en' } = Astro.props;

// Tech stack with SVG icons
const techs = [
  { name: 'React', color: '#61DAFB', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="2.5"/><ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="currentColor" stroke-width="1.5"/><ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4" fill="none" stroke="currentColor" stroke-width="1.5" transform="rotate(120 12 12)"/></svg>` },
  { name: 'TypeScript', color: '#3178C6', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="M8 15.5c1.2 1.8 3.2 2.5 5 2 1.3-.4 2-1.5 2-2.5 0-1.5-1.5-2.5-3.5-3.5l-1-1c-3-1.5-5-3-5-6 0-3 2.5-5.5 6-5.5 2.8 0 4.5 1.2 5.5 4.5" fill="none" stroke="white" stroke-width="1.5"/><path d="M18 10l-2 1 2 1" fill="none" stroke="white" stroke-width="1.5"/></svg>` },
  { name: 'Next.js', color: '#ffffff', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.6"/><path d="M2 12l10 5 10-5" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>` },
  { name: 'Astro', color: '#FF5D01', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5z" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3"/></svg>` },
  { name: 'Node.js', color: '#339933', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2v10l8 5-8 5v10l-8-5v-10l8-5-8-5z" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M12 2v20M4 7l8 5 8-5M4 17l8 5 8-5" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"/></svg>` },
  { name: 'Tailwind', color: '#06B6D4', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm-6 8c0-1.66 1.34-3 3-3s3 1.34 3 3-1.34 3-3 3-3 1.34-3 3zm12 0c0 1.66-1.34 3-3 3s-3-1.34-3-3 1.34-3 3-3 3 1.34 3 3z"/></svg>` },
  { name: 'PostgreSQL', color: '#336791', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><ellipse cx="12" cy="6" rx="8" ry="3.5" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M4 6v6c0 1.93 3.58 3.5 8 3.5s8-1.57 8-3.5V6" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M4 12v6c0 1.93 3.58 3.5 8 3.5s8-1.57 8-3.5v-6" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.5"/></svg>` },
  { name: 'Docker', color: '#2496ED', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="4" height="4" rx="1"/><rect x="10" y="3" width="4" height="4" rx="1"/><rect x="17" y="3" width="4" height="4" rx="1"/><rect x="3" y="10" width="4" height="4" rx="1"/><rect x="10" y="10" width="4" height="4" rx="1"/><rect x="17" y="10" width="4" height="4" rx="1"/><rect x="3" y="17" width="4" height="4" rx="1"/><rect x="10" y="17" width="4" height="4" rx="1"/><rect x="17" y="17" width="4" height="4" rx="1"/></svg>` },
  { name: 'Git', color: '#F05032', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M21.62 11.11l-8.73-8.73a1.3 1.3 0 0 0-1.84 0l-1.81 1.81 2.3 2.3a1.55 1.55 0 0 1 1.96 1.97l2.22 2.22a1.55 1.55 0 1 1-.93.9l-2.07-2.07v5.45a1.55 1.55 0 1 1-1.28-.01V12.4L8.5 16.86a1.3 1.3 0 0 0 0 1.84l8.73 8.73a1.3 1.3 0 0 0 1.84 0l8.68-8.68a1.3 1.3 0 0 0 0-1.84l-.13-.13z"/></svg>` },
  { name: 'Figma', color: '#F24E1E', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="2" width="8" height="8" rx="1.5"/><rect x="14" y="2" width="8" height="8" rx="1.5"/><rect x="2" y="14" width="8" height="8" rx="1.5"/><rect x="14" y="14" width="8" height="8" rx="1.5"/></svg>` },
  { name: 'Vercel', color: '#ffffff', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 2 22 22 22"/></svg>` },
  { name: 'GraphQL', color: '#E10098', svg: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L3 7v10l9 5 9-5V7l-9-5z" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="2.5"/><path d="M12 2v5M12 17v5M2 7l4.5 3M17.5 17l4.5-3M2 17l4.5-3M17.5 7l4.5 3" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5"/></svg>` },
];

// Duplicate for seamless loop
const doubled = [...techs, ...techs];
---

<div class="py-8 overflow-hidden" style="border-top: 1px solid var(--color-ink-faint); border-bottom: 1px solid var(--color-ink-faint);">
  <div class="marquee-track flex items-center gap-0" style="width: max-content;">
    {doubled.map((tech, i) => (
      <div
        class="flex items-center gap-2.5 px-6 py-2 rounded-full mx-1 hover-scale"
        style="background: var(--color-surface); border: 1px solid var(--color-ink-faint); white-space: nowrap;"
      >
        <span class="w-4 h-4 flex-shrink-0" style={`color: ${tech.color};`} set:html={tech.svg} />
        <span class="text-xs font-medium" style="color: var(--color-ink);">{tech.name}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 30s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>
