];

// Duplicate for seamless loop
const doubled = [...techs, ...techs];
---

<div class="py-5 overflow-hidden" style="border-top: 1px solid var(--color-ink-faint); border-bottom: 1px solid var(--color-ink-faint);">
  <div class="marquee-track flex items-center" style="width: max-content;">
    {doubled.map((tech, i) => (
      <div
        class="flex items-center gap-2 px-5 py-1.5 rounded-full mx-1 transition-all duration-200 cursor-default"
        style="background: var(--color-surface); border: 1px solid var(--color-ink-faint); white-space: nowrap;"
      >
        <span
          class="w-4 h-4 flex-shrink-0 [&_svg]:w-full [&_svg]:h-full [&_svg]:block"
          style="color: var(--color-ink);"
          set:html={tech.svg}
        />
        <span class="text-xs font-medium tracking-wide" style="color: var(--color-ink);">
          {tech.name}
        </span>
      </div>
    ))}
  </div>
</div>

<style>
  .marquee-track {
    animation: marquee 35s linear infinite;
  }
  .marquee-track:hover {
    animation-play-state: paused;
  }
</style>
