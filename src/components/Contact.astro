---
interface Props {
  locale?: 'en' | 'id';
  email?: string;
}

const { locale = 'en', email = 'hello@yourname.dev' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);

const socials = [
  {
    name: 'GitHub',
    url: 'https://github.com/yourusername',
    label: 'github.com/yourusername',
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com/in/yourusername',
    label: 'linkedin.com/in/yourusername',
  },
  {
    name: 'X / Twitter',
    url: 'https://x.com/yourusername',
    label: 'x.com/yourusername',
  },
  {
    name: 'Dribbble',
    url: 'https://dribbble.com/yourusername',
    label: 'dribbble.com/yourusername',
  },
];
---

<section id="contact" class="py-24 md:py-40" style="background-color: var(--color-ink);">
  <div class="container-wide">

    <!-- Top: section label -->
    <div class="reveal mb-20">
      <p class="font-mono text-xs tracking-widest" style="color: rgba(250,250,250,0.3);">
        {`0${locale === 'en' ? '4' : '4'} / ${t.contact.label.toUpperCase()}`}
      </p>
    </div>

    <!-- Headline -->
    <div class="mb-20">
      <h2
        class="reveal font-display font-bold leading-none"
        style="
          font-size: clamp(3rem, 9vw, 7rem);
          letter-spacing: -0.05em;
          color: var(--color-bg);
          line-height: 0.92;
        "
      >
        {t.contact.headline}
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-end">

      <!-- Left: CTA -->
      <div class="lg:col-span-5">
        <p class="reveal text-base leading-relaxed mb-10" style="color: rgba(250,250,250,0.45);">
          {t.contact.sub}
        </p>

        <div class="reveal">
          <a
            href={`mailto:${email}?subject=${locale === 'id' ? 'Hai, saya ingin bekerja sama' : 'Hi, let\'s work together'}`}
            class="group inline-flex items-center gap-3 text-base font-medium transition-all duration-200"
            style="color: var(--color-bg);"
          >
            <span class="relative">
              {t.contact.email}
              <span
                class="absolute -bottom-0.5 left-0 w-0 h-px transition-all duration-300 group-hover:w-full"
                style="background: var(--color-bg); opacity: 0.4;"
              ></span>
            </span>
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Social links -->
      <div class="lg:col-span-6 lg:col-start-7">
        <p class="reveal font-mono text-xs mb-6 tracking-widest" style="color: rgba(250,250,250,0.25);">
          {t.contact.social.toUpperCase()}
        </p>
        <div class="flex flex-col">
          {socials.map((social, i) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="reveal group flex items-center justify-between py-4 transition-all duration-200 hover:pl-3"
              style={`border-bottom: 1px solid rgba(250,250,250,0.08); transition-delay: ${i * 60}ms;`}
            >
              <div class="flex flex-col">
                <span class="text-sm font-medium" style="color: var(--color-bg);">
                  {social.name}
                </span>
                <span class="font-mono text-xs mt-0.5" style="color: rgba(250,250,250,0.35);">
                  {social.label}
                </span>
              </div>
              <svg
                class="w-4 h-4 opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                style="color: rgba(250,250,250,0.4);"
              >
                <path d="M7 17L17 7M7 7h10v10"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

  </div>
</section>
