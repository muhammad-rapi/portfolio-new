---
interface Props {
  title: string;
  description: string;
  year: number;
  tags: string[];
  slug: string;
  image?: string;
  liveUrl?: string;
  repoUrl?: string;
  locale?: 'en' | 'id';
}

const {
  title,
  description,
  year,
  tags,
  slug,
  image,
  liveUrl,
  locale = 'en',
} = Astro.props;

const t = await import(`../i18n/${locale}.json`);
const projectUrl = locale === 'id' ? `/id/projects/${slug}` : `/projects/${slug}`;
---

<article class="reveal group">
  <!-- Image with overlay on hover -->
  <a href={projectUrl} class="block mb-5 overflow-hidden rounded-xl" style="aspect-ratio: 16/10; position: relative;">
    <img
      src={image || 'https://picsum.photos/800/500'}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <!-- Overlay on hover -->
    <div
      class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300"
      style="background: rgba(28,28,28,0.7);"
    >
      <div class="flex items-center gap-2 text-sm" style="color: #F7F6F3;">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        View Case Study
      </div>
    </div>
  </a>

  <!-- Meta -->
  <div class="flex items-start justify-between gap-4 mb-2">
    <a href={projectUrl}>
      <h3
        class="font-display font-bold text-base leading-tight transition-all duration-200 group-hover:opacity-60"
        style="color: var(--color-ink);"
      >
        {title}
      </h3>
    </a>
    <span class="font-mono text-xs flex-shrink-0 mt-0.5" style="color: var(--color-ink-muted);">{year}</span>
  </div>

  <p class="text-sm leading-relaxed mb-3" style="color: var(--color-ink-muted);">
    {description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, 3).map(tag => (
      <span
        class="font-mono text-xs px-2 py-0.5 rounded-full transition-all duration-200 group-hover:bg-opacity-60"
        style="background: var(--color-ink-faint); color: var(--color-ink-muted);"
      >
        {tag}
      </span>
    ))}
    {tags.length > 3 && (
      <span class="font-mono text-xs" style="color: var(--color-ink-muted);">+{tags.length - 3}</span>
    )}
  </div>
</article>
