---
interface Props {
  title: string;
  description: string;
  year: number;
  tags: string[];
  slug: string;
  image?: string;
  liveUrl?: string;
  repoUrl?: string;
  locale?: 'en' | 'id';
}

const {
  title,
  description,
  year,
  tags,
  slug,
  image,
  liveUrl,
  repoUrl,
  locale = 'en',
} = Astro.props;

const t = await import(`../i18n/${locale}.json`);
const projectUrl = locale === 'id' ? `/id/projects/${slug}` : `/projects/${slug}`;
---

<article class="project-card group">
  <!-- Mockup Image -->
  <a href={projectUrl} class="block browser-mockup mb-5 overflow-hidden" style="aspect-ratio: 16/10;">
    <div class="project-image w-full h-full flex items-center justify-center overflow-hidden" style="background: var(--color-ink-faint);">
      {image ? (
        <img
          src={image}
          alt={`${title} screenshot`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="flex flex-col items-center justify-center h-full gap-3 p-8">
          <div class="w-16 h-12 rounded border-2 border-dashed flex items-center justify-center" style="border-color: var(--color-ink-muted);">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: var(--color-ink-muted);">
              <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          <span class="font-mono text-xs" style="color: var(--color-ink-muted);">{title}</span>
        </div>
      )}
    </div>
  </a>

  <!-- Meta -->
  <div class="px-1">
    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map(tag => (
        <span class="badge">{tag}</span>
      ))}
    </div>

    <!-- Title + Year -->
    <div class="flex items-start justify-between gap-4 mb-2">
      <a href={projectUrl} class="group/title">
        <h3
          class="font-display font-bold text-lg leading-tight transition-colors group-hover/title:text-[var(--color-ink-muted)]"
          style="color: var(--color-ink);"
        >
          {title}
        </h3>
      </a>
      <span class="font-mono text-xs flex-shrink-0 mt-1" style="color: var(--color-ink-muted);">{year}</span>
    </div>

    <!-- Description -->
    <p class="text-sm leading-relaxed mb-4" style="color: var(--color-ink-muted);">
      {description}
    </p>

    <!-- Links -->
    <div class="flex items-center gap-4">
      <a
        href={projectUrl}
        class="inline-flex items-center gap-1.5 text-sm font-medium link-underline"
        style="color: var(--color-ink);"
      >
        {t.projects.view_case}
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-medium link-underline"
          style="color: var(--color-ink-muted);"
        >
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"/>
          </svg>
          {t.projects.view_live}
        </a>
      )}
    </div>
  </div>
</article>
