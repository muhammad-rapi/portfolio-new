---
interface Props {
  locale?: 'en' | 'id';
  name?: string;
}

const { locale = 'en', name = 'Your Name' } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="py-8 border-t" style="border-color: var(--color-ink-faint);">
  <div class="container-wide">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <div class="flex items-center gap-4">
        <a
          href={locale === 'en' ? '/' : '/id'}
          class="font-display font-bold text-sm"
          style="color: var(--color-ink);"
        >
          {name}
        </a>
        <span class="font-mono text-xs" style="color: var(--color-ink-muted);">
          &copy; {year}
        </span>
      </div>
      <p class="font-mono text-xs" style="color: var(--color-ink-muted);">
        Built with Astro &amp; Tina CMS
      </p>
    </div>
  </div>
</footer>
