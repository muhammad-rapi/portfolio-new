---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

interface Props {
  locale?: 'en' | 'id';
  limit?: number;
}

const { locale = 'en', limit = 6 } = Astro.props;
const t = await import(`../i18n/${locale}.json`);

function getSlug(id: string): string {
  return id.replace(/en$/, '').replace(/id$/, '');
}

const allProjects = await getCollection('projects');
const filtered = allProjects
  .filter(p => locale === 'en' ? p.id.endsWith('en') : p.id.endsWith('id'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, limit);
---

<section id="work" class="py-24 md:py-32" style="background-color: var(--color-surface);">
  <div class="container-wide">
    <!-- Header -->
    <div class="flex items-end justify-between mb-14">
      <div class="reveal">
        <p class="font-mono text-xs mb-3 tracking-widest" style="color: var(--color-ink-muted);">
          {t.projects.label.toUpperCase()}
        </p>
        <h2
          class="font-display font-bold"
          style="font-size: clamp(1.75rem, 4vw, 2.75rem); letter-spacing: -0.04em; color: var(--color-ink); line-height: 1;"
        >
          Things I've<br/>Built
        </h2>
      </div>
      <div class="hidden sm:block">
        <div class="w-16 h-px mb-2" style="background: var(--color-ink-faint);"></div>
        <p class="font-mono text-xs" style="color: var(--color-ink-muted);">{filtered.length} {locale === 'en' ? 'projects' : 'proyek'}</p>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14">
      {filtered.map((project, i) => (
        <div class="reveal" style={`transition-delay: ${i * 80}ms;`}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            year={project.data.year}
            tags={project.data.tags}
            slug={getSlug(project.id)}
            image={project.data.image}
            liveUrl={project.data.liveUrl}
            repoUrl={project.data.repoUrl}
            locale={locale}
          />
        </div>
      ))}
    </div>
  </div>
</section>
