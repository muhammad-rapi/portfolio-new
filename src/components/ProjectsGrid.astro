---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

interface Props {
  locale?: 'en' | 'id';
  limit?: number;
}

const { locale = 'en', limit = 6 } = Astro.props;
const t = await import(`../i18n/${locale}.json`);

function getSlug(id: string): string {
  return id.replace(/en$/, '').replace(/id$/, '');
}

const allProjects = await getCollection('projects');
const filtered = allProjects
  .filter(p => locale === 'en' ? p.id.endsWith('en') : p.id.endsWith('id'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, limit);
---

<section id="work" class="section">
  <div class="container-wide">
    <!-- Header -->
    <div class="flex items-end justify-between mb-12">
      <div>
        <p class="reveal font-mono text-xs mb-3 tracking-widest uppercase" style="color: var(--color-ink-muted);">
          {t.projects.label}
        </p>
        <h2
          class="reveal font-display font-bold"
          style="font-size: clamp(1.75rem, 4vw, 3rem); letter-spacing: -0.03em; color: var(--color-ink);"
        >
          Featured Projects
        </h2>
      </div>
      <a
        href={locale === 'id' ? '/id/projects' : '/projects'}
        class="hidden sm:inline-flex items-center gap-2 text-sm font-medium link-underline"
        style="color: var(--color-ink-muted);"
      >
        {t.projects.view_all}
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
      {filtered.map((project, i) => (
        <div class="reveal" style={`transition-delay: ${i * 80}ms;`}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            year={project.data.year}
            tags={project.data.tags}
            slug={getSlug(project.id)}
            image={project.data.image}
            liveUrl={project.data.liveUrl}
            repoUrl={project.data.repoUrl}
            locale={locale}
          />
        </div>
      ))}
    </div>

    <!-- Mobile view all -->
    <div class="sm:hidden mt-8 text-center">
      <a
        href={locale === 'id' ? '/id/projects' : '/projects'}
        class="inline-flex items-center gap-2 text-sm font-medium link-underline"
        style="color: var(--color-ink-muted);"
      >
        {t.projects.view_all}
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
