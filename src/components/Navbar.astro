---
interface Props {
  locale?: 'en' | 'id';
}
const { locale = 'en' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);
const langPrefix = locale === 'id' ? '/id' : '';
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50">
  <div class="container-wide">
    <nav class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={langPrefix + '/'}
        class="font-display font-bold text-lg tracking-tight"
        style="color: var(--nav-ink);"
      >
        YN.
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="nav-link text-sm transition-all duration-200 hover:opacity-50" style="color: var(--nav-muted);">
          {t.nav.about}
        </a>
        <a href="#work" class="nav-link text-sm transition-all duration-200 hover:opacity-50" style="color: var(--nav-muted);">
          {t.nav.work}
        </a>
        <a href="#contact" class="nav-link text-sm transition-all duration-200 hover:opacity-50" style="color: var(--nav-muted);">
          {t.nav.contact}
        </a>
        <div class="flex items-center gap-3">
          <!-- Theme Toggle -->
          <button
            id="theme-toggle"
            class="p-1.5 rounded transition-all duration-200 hover:opacity-50"
            style="color: var(--nav-muted);"
            aria-label="Toggle theme"
          >
            <!-- Moon icon (show in light mode) -->
            <svg id="moon-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <!-- Sun icon (show in dark mode) -->
            <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
          <span style="color: var(--nav-muted); opacity: 0.3;">|</span>
          <a
            href={locale === 'en' ? '/id' : '/'}
            class="text-xs font-mono transition-all duration-200 hover:opacity-50"
            style="color: var(--nav-muted);"
          >
            {locale === 'en' ? 'ID' : 'EN'}
          </a>
        </div>
      </div>

      <!-- Mobile right side -->
      <div class="flex md:hidden items-center gap-2">
        <button
          id="theme-toggle-mobile"
          class="p-1.5"
          style="color: var(--nav-muted);"
          aria-label="Toggle theme"
        >
          <svg id="moon-icon-mobile" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg id="sun-icon-mobile" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
          </svg>
        </button>
        <button id="mobile-toggle" class="flex flex-col gap-1.5 p-2" aria-label="Menu">
          <span class="block w-5 h-px transition-all duration-200" style="background: var(--nav-ink);"></span>
          <span class="block w-5 h-px transition-all duration-200" style="background: var(--nav-ink);"></span>
          <span class="block w-3 h-px transition-all duration-200" style="background: var(--nav-ink);"></span>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="border-color: var(--nav-border); background: var(--color-bg);"
  >
    <div class="container-wide py-8 flex flex-col gap-6">
      <a href="#about" class="mobile-link text-sm" style="color: var(--nav-muted);">{t.nav.about}</a>
      <a href="#work" class="mobile-link text-sm" style="color: var(--nav-muted);">{t.nav.work}</a>
      <a href="#contact" class="mobile-link text-sm" style="color: var(--nav-muted);">{t.nav.contact}</a>
      <a href={locale === 'en' ? '/id' : '/'} class="text-xs font-mono" style="color: var(--nav-muted);">
        {locale === 'en' ? 'Bahasa Indonesia' : 'English'}
      </a>
    </div>
  </div>
</header>

<style>
  /* Light mode — soft gray nav */
  [data-theme="light"],
  html:not([data-theme]) {
    --nav-ink: #1A1A1A;
    --nav-muted: #888888;
    --nav-border: #EBEBEB;
    --nav-bg: rgba(250,250,250,0);
    --nav-bg-scroll: rgba(250,250,250,0.88);
  }
  /* Dark mode — dark nav with light text */
  [data-theme="dark"] {
    --nav-ink: #F0F0F0;
    --nav-muted: #888888;
    --nav-border: #1E1E1E;
    --nav-bg: rgba(10,10,10,0);
    --nav-bg-scroll: rgba(10,10,10,0.88);
  }
</style>

<script>
  const navbar = document.getElementById('navbar') as HTMLElement;

  // Scroll effect — apply bg to navbar element directly
  function updateNavbar() {
    if (window.scrollY > 20) {
      navbar.style.background = 'var(--nav-bg-scroll)';
      navbar.style.backdropFilter = 'blur(16px)';
      navbar.style.webkitBackdropFilter = 'blur(16px)';
      navbar.style.borderBottom = '1px solid var(--nav-border)';
    } else {
      navbar.style.background = 'transparent';
      navbar.style.backdropFilter = 'none';
      navbar.style.webkitBackdropFilter = 'none';
      navbar.style.borderBottom = 'none';
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Theme toggle
  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    const moon = document.getElementById('moon-icon');
    const sun = document.getElementById('sun-icon');
    const moonM = document.getElementById('moon-icon-mobile');
    const sunM = document.getElementById('sun-icon-mobile');
    if (theme === 'dark') {
      moon?.classList.add('hidden'); sun?.classList.remove('hidden');
      moonM?.classList.add('hidden'); sunM?.classList.remove('hidden');
    } else {
      moon?.classList.remove('hidden'); sun?.classList.add('hidden');
      moonM?.classList.remove('hidden'); sunM?.classList.add('hidden');
    }
    updateNavbar();
  }

  const savedTheme = localStorage.getItem('theme') ||
    (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
  applyTheme(savedTheme);

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    applyTheme(next);
  });
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    applyTheme(next);
  });

  // Mobile menu
  const mobileToggle = document.getElementById('mobile-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileToggle?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
  document.querySelectorAll('.mobile-link').forEach(l =>
    l.addEventListener('click', () => mobileMenu?.classList.add('hidden'))
  );
</script>
