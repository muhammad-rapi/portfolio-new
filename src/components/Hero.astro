---
interface Props {
  locale?: 'en' | 'id';
  name?: string;
}
const { locale = 'en', name = 'Your Name' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center" style="padding-top: 80px;">
  <div class="container-wide py-24 md:py-36">

    <!-- Greeting line -->
    <div class="reveal flex items-center gap-3 mb-12">
      <span class="w-8 h-px" style="background: var(--color-ink-faint);"></span>
      <span class="font-mono text-xs tracking-widest" style="color: var(--color-ink-muted);">
        HELLO
      </span>
    </div>

    <!-- Name — editorial, oversized -->
    <h1
      class="reveal font-display font-bold leading-none mb-2"
      style="
        font-size: clamp(3.5rem, 11vw, 8rem);
        letter-spacing: -0.05em;
        color: var(--color-ink);
        line-height: 0.9;
      "
    >
      {name}
    </h1>

    <!-- Role — understated, next line -->
    <div class="reveal mt-6 mb-10">
      <div class="flex items-center gap-4">
        <p
          class="font-display text-base md:text-lg"
          style="
            color: var(--color-ink-muted);
            letter-spacing: -0.01em;
          "
        >
          {t.hero.role}
        </p>
        <span class="flex items-center gap-1.5">
          <span class="inline-block w-1.5 h-1.5 rounded-full" style="background: #22c55e;"></span>
          <span class="font-mono text-xs" style="color: var(--color-ink-muted);">
            {locale === 'en' ? 'Available' : 'Tersedia'}
          </span>
        </span>
      </div>
    </div>

    <!-- Tagline -->
    <p
      class="reveal text-base md:text-lg mb-14 max-w-xl leading-relaxed"
      style="color: var(--color-ink-muted);"
    >
      {t.hero.tagline}
    </p>

    <!-- CTA row -->
    <div class="reveal flex flex-wrap items-center gap-5">
      <a
        href="#work"
        class="group inline-flex items-center gap-3 text-sm font-medium px-6 py-3 transition-all duration-200"
        style="
          background: var(--color-ink);
          color: var(--color-bg);
          border-radius: 2px;
        "
      >
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
        {t.hero.cta_work}
      </a>
      <a
        href="#contact"
        class="group inline-flex items-center gap-2 text-sm px-4 py-3 transition-all duration-200"
        style="color: var(--color-ink-muted); border-bottom: 1px solid var(--color-ink-faint);"
      >
        {t.hero.cta_cv}
        <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Bottom strip -->
    <div class="absolute bottom-10 left-0 right-0 container-wide">
      <div class="flex items-center justify-between pt-8" style="border-top: 1px solid var(--color-ink-faint);">
        <div class="flex items-center gap-8">
          <div>
            <p class="font-display font-bold text-lg" style="color: var(--color-ink);">5+</p>
            <p class="font-mono text-xs" style="color: var(--color-ink-muted);">
              {locale === 'en' ? 'Years' : 'Tahun'}
            </p>
          </div>
          <div class="w-px h-8" style="background: var(--color-ink-faint);"></div>
          <div>
            <p class="font-display font-bold text-lg" style="color: var(--color-ink);">40+</p>
            <p class="font-mono text-xs" style="color: var(--color-ink-muted);">
              {locale === 'en' ? 'Projects' : 'Proyek'}
            </p>
          </div>
          <div class="w-px h-8" style="background: var(--color-ink-faint);"></div>
          <div>
            <p class="font-display font-bold text-lg" style="color: var(--color-ink);">20+</p>
            <p class="font-mono text-xs" style="color: var(--color-ink-muted);">
              {locale === 'en' ? 'Clients' : 'Klien'}
            </p>
          </div>
        </div>
        <!-- Scroll indicator -->
        <div class="flex items-center gap-3">
          <div class="w-px h-10 overflow-hidden rounded-full" style="background: var(--color-ink-faint);">
            <div style="
              width: 100%; height: 100%;
              background: var(--color-ink-muted);
              animation: scroll-indicator 1.8s ease-in-out infinite;
            "></div>
          </div>
          <span class="font-mono text-xs hidden sm:block" style="color: var(--color-ink-muted);">Scroll</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-indicator {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(250%); }
  }
</style>
