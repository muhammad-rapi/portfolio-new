---
interface Props {
  locale?: 'en' | 'id';
  name?: string;
}
const { locale = 'en', name = 'Your Name' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);
---

<section id="hero" class="relative min-h-screen flex flex-col justify-center" style="padding-top: 80px;">
  <div class="container-wide py-32 md:py-40">

    <!-- Status badge -->
    <div class="reveal flex items-center gap-2 mb-10">
      <span class="inline-block w-2 h-2 rounded-full" style="background: #22c55e; animation: float 2s ease-in-out infinite;"></span>
      <span class="font-mono text-xs" style="color: var(--color-ink-muted);">
        {locale === 'en' ? 'Available for work' : 'Tersedia untuk bekerja'}
      </span>
    </div>

    <!-- Name -->
    <h1
      class="reveal font-display font-bold mb-2 leading-none"
      style="
        font-size: clamp(3rem, 10vw, 7rem);
        letter-spacing: -0.04em;
        color: var(--color-ink);
      "
    >
      {name}
    </h1>

    <!-- Role with icon -->
    <div class="reveal flex items-center gap-3 mb-6">
      <span class="block w-8 h-px" style="background: var(--color-ink-muted);"></span>
      <p
        class="font-display font-medium"
        style="
          font-size: clamp(1rem, 2.5vw, 1.35rem);
          color: var(--color-ink-muted);
          letter-spacing: -0.01em;
        "
      >
        {t.hero.role}
      </p>
    </div>

    <!-- Tagline -->
    <p
      class="reveal text-base md:text-lg mb-12 max-w-lg leading-relaxed"
      style="color: var(--color-ink-muted);"
    >
      {t.hero.tagline}
    </p>

    <!-- CTAs -->
    <div class="reveal flex flex-wrap items-center gap-6">
      <a
        href="#work"
        class="group inline-flex items-center gap-3 text-sm font-medium px-5 py-2.5 rounded-full transition-all duration-200"
        style="
          background: var(--color-ink);
          color: var(--color-bg);
        "
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        {t.hero.cta_work}
      </a>
      <a
        href="/cv.pdf"
        class="group inline-flex items-center gap-2 text-sm transition-all duration-200 hover:opacity-60"
        style="color: var(--color-ink-muted);"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {t.hero.cta_cv}
      </a>
    </div>

    <!-- Stats row -->
    <div class="reveal mt-20 flex flex-wrap gap-10 pt-8" style="border-top: 1px solid var(--color-ink-faint);">
      <div>
        <p class="font-display font-bold text-2xl" style="color: var(--color-ink);">5+</p>
        <p class="text-xs mt-0.5" style="color: var(--color-ink-muted);">
          {locale === 'en' ? 'Years Experience' : 'Tahun Pengalaman'}
        </p>
      </div>
      <div>
        <p class="font-display font-bold text-2xl" style="color: var(--color-ink);">40+</p>
        <p class="text-xs mt-0.5" style="color: var(--color-ink-muted);">
          {locale === 'en' ? 'Projects Shipped' : 'Proyek Terkirim'}
        </p>
      </div>
      <div>
        <p class="font-display font-bold text-2xl" style="color: var(--color-ink);">20+</p>
        <p class="text-xs mt-0.5" style="color: var(--color-ink-muted);">
          {locale === 'en' ? 'Happy Clients' : 'Klien Puas'}
        </p>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <span class="text-xs font-mono" style="color: var(--color-ink-muted);">Scroll</span>
    <div class="w-px h-8 overflow-hidden rounded-full" style="background: var(--color-ink-faint);">
      <div style="
        width: 100%; height: 100%;
        background: var(--color-ink-muted);
        animation: scroll-indicator 1.8s ease-in-out infinite;
      "></div>
    </div>
  </div>
</section>

<style>
  @keyframes scroll-indicator {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(250%); }
  }
</style>
