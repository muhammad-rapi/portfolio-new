---
interface Props {
  locale?: 'en' | 'id';
}

const { locale = 'en' } = Astro.props;
const t = await import(`../i18n/${locale}.json`);

const experiences = [
  {
    company: 'Tech Company A',
    role: locale === 'id' ? 'Senior Full-Stack Developer' : 'Senior Full-Stack Developer',
    period: '2022 — Sekarang',
    description: locale === 'id'
      ? 'Memimpin pengembangan aplikasi web skala enterprise dengan React dan Node.js. Meningkatkan performa aplikasi hingga 40%.'
      : 'Led development of enterprise-scale web applications using React and Node.js. Improved application performance by 40%.',
  },
  {
    company: 'Startup B',
    role: locale === 'id' ? 'Frontend Developer' : 'Frontend Developer',
    period: '2020 — 2022',
    description: locale === 'id'
      ? 'Membangun UI/UX untuk platform e-commerce menggunakan Vue.js dan Tailwind CSS. Collaborated dengan tim desain closely.'
      : 'Built UI/UX for an e-commerce platform using Vue.js and Tailwind CSS. Collaborated closely with the design team.',
  },
  {
    company: 'Agency C',
    role: locale === 'id' ? 'Web Developer' : 'Web Developer',
    period: '2018 — 2020',
    description: locale === 'id'
      ? 'Mengembangkan berbagai website klien menggunakan React dan Next.js. Shipped 15+ project berkualitas tinggi.'
      : 'Developed various client websites using React and Next.js. Shipped 15+ high-quality projects.',
  },
];
---

<section id="experience" class="section">
  <div class="container-wide">
    <!-- Label -->
    <p class="reveal font-mono text-xs mb-3 tracking-widest uppercase" style="color: var(--color-ink-muted);">
      {t.experience.label}
    </p>
    <h2
      class="reveal font-display font-bold mb-16"
      style="font-size: clamp(1.75rem, 4vw, 3rem); letter-spacing: -0.03em; color: var(--color-ink);"
    >
      Career Path
    </h2>

    <!-- Timeline -->
    <div class="relative max-w-2xl">
      {experiences.map((exp, i) => (
        <div
          class="reveal relative pl-10 pb-12 last:pb-0"
          style={`transition-delay: ${i * 120}ms;`}
        >
          <!-- Line -->
          {i < experiences.length - 1 && (
            <div
              class="timeline-line"
              style="top: 8px;"
            ></div>
          )}

          <!-- Dot -->
          <div class="timeline-dot absolute left-0 top-1"></div>

          <!-- Content -->
          <div>
            <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mb-1">
              <h3 class="font-display font-bold text-base" style="color: var(--color-ink);">
                {exp.company}
              </h3>
              <span class="font-mono text-xs hidden sm:block" style="color: var(--color-ink-muted);">—</span>
              <span class="font-mono text-xs" style="color: var(--color-ink-muted);">{exp.period}</span>
            </div>
            <p class="font-medium text-sm mb-2" style="color: var(--color-ink-muted);">
              {exp.role}
            </p>
            <p class="text-sm leading-relaxed" style="color: var(--color-ink-muted);">
              {exp.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
